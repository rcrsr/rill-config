{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "coverage",
    "*.md",
    "*.html",
    "*.css",
    "*.toml",
    "pnpm-lock.yaml"
  ]
}
