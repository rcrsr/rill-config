{
  "name": "@rcrsr/rill-config",
  "version": "0.19.2",
  "description": "Shared config library for rill resolution, validation, loading, and bindings generation",
  "license": "MIT",
  "author": "Andre Bremer",
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "keywords": [
    "rill",
    "config",
    "scripting",
    "extensions",
    "project-loader"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "lefthook install --force",
    "build": "tsc --build",
    "build:dev": "tsc --build tsconfig.dev.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "oxlint --config .oxlintrc.json src/ tests/",
    "check": "pnpm run build && pnpm run test && pnpm run check:lint",
    "check:types": "pnpm run typecheck",
    "check:lint": "pnpm run lint",
    "check:format": "oxfmt --check",
    "check:deps": "knip",
    "fix:lint": "oxlint --config .oxlintrc.json --fix src/ tests/",
    "fix:format": "oxfmt"
  },
  "dependencies": {
    "semver": "^7.7.4"
  },
  "peerDependencies": {
    "@rcrsr/rill": "~0.19.0"
  },
  "devDependencies": {
    "@rcrsr/rill": "~0.19.0",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "knip": "^6.25.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill-config.git"
  },
  "homepage": "https://github.com/rcrsr/rill-config",
  "bugs": {
    "url": "https://github.com/rcrsr/rill-config/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
