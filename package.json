{
  "name": "@rcrsr/rill-config",
  "version": "0.19.1",
  "description": "Shared config library for rill resolution, validation, loading, and bindings generation",
  "license": "MIT",
  "author": "Andre Bremer",
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "keywords": [
    "rill",
    "config",
    "scripting",
    "extensions",
    "project-loader"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:dev": "tsc --build tsconfig.dev.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "pnpm run build && pnpm run test && pnpm run lint"
  },
  "dependencies": {
    "semver": "^7.7.4"
  },
  "peerDependencies": {
    "@rcrsr/rill": "~0.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rcrsr/rill": "~0.19.0",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill-config.git"
  },
  "homepage": "https://github.com/rcrsr/rill-config",
  "bugs": {
    "url": "https://github.com/rcrsr/rill-config/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
